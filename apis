<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>VIP HS ULTIMATE | ALL IN ONE</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: radial-gradient(circle at 20% 30%, #0a0e1a, #020408);
            font-family: 'Courier New', 'Monaco', monospace;
            min-height: 100vh;
            padding: 16px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .app {
            max-width: 550px;
            width: 100%;
            background: rgba(8, 18, 28, 0.96);
            backdrop-filter: blur(16px);
            border-radius: 48px;
            border: 2px solid #0ff;
            box-shadow: 0 20px 40px rgba(0,0,0,0.6), 0 0 20px rgba(0,255,255,0.2);
            padding: 22px;
        }

        h1 {
            text-align: center;
            color: #0ff;
            font-size: 1.6rem;
            letter-spacing: 2px;
        }

        .sub {
            text-align: center;
            color: #88aaff;
            font-size: 0.65rem;
            margin-bottom: 20px;
        }

        /* GENERATE SECTION */
        .gen-box {
            background: #010a14cc;
            border-radius: 28px;
            padding: 18px;
            margin-bottom: 18px;
            border: 1px solid #ff44aa;
        }

        .btn-gen {
            background: linear-gradient(90deg, #ff8800, #ffcc00);
            width: 100%;
            padding: 14px;
            font-size: 1.1rem;
            font-weight: bold;
            border: none;
            border-radius: 60px;
            cursor: pointer;
            font-family: monospace;
        }

        .key-area {
            background: #000000aa;
            border-radius: 24px;
            padding: 16px;
            margin-top: 14px;
            text-align: center;
            display: none;
        }

        .key-value {
            font-size: 1rem;
            font-weight: bold;
            color: #ffff00;
            background: #0a0a0a;
            padding: 12px;
            border-radius: 16px;
            border: 2px solid cyan;
            word-break: break-all;
            cursor: pointer;
            margin: 10px 0;
        }

        .copy-row {
            display: flex;
            gap: 10px;
        }

        .copy-btn {
            flex: 1;
            background: #2a6f8f;
            padding: 8px;
            border: none;
            border-radius: 40px;
            cursor: pointer;
            font-weight: bold;
        }

        .key-list {
            margin-top: 14px;
            max-height: 130px;
            overflow-y: auto;
        }

        .key-item {
            background: #0f1a24;
            padding: 6px 10px;
            margin: 4px 0;
            border-radius: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 6px;
        }

        .key-item span {
            color: #aaffaa;
            font-size: 0.7rem;
            cursor: pointer;
            flex: 1;
            word-break: break-all;
        }

        .item-copy, .item-del {
            border: none;
            border-radius: 30px;
            padding: 4px 12px;
            cursor: pointer;
            font-size: 0.65rem;
        }

        .item-copy { background: #2a6f8f; }
        .item-del { background: #ff3355; color: white; }

        /* LOGIN SECTION */
        .login-box {
            background: #010a14cc;
            border-radius: 28px;
            padding: 18px;
            margin-bottom: 10px;
            border: 1px solid cyan;
        }

        .key-input {
            width: 100%;
            background: black;
            border: 2px solid cyan;
            padding: 12px;
            border-radius: 60px;
            color: #0f0;
            font-size: 0.9rem;
            text-align: center;
            margin: 10px 0;
        }

        .btn-login {
            background: linear-gradient(95deg, #0fa, #0af);
            width: 100%;
            padding: 12px;
            font-weight: bold;
            border: none;
            border-radius: 60px;
            cursor: pointer;
        }

        /* DASHBOARD */
        .dashboard {
            display: none;
        }

        .card {
            background: #000000aa;
            border-radius: 24px;
            padding: 16px;
            margin: 14px 0;
            border-left: 4px solid #ff3366;
        }

        .toggle-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 60px;
            height: 30px;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #2c2f3a;
            border-radius: 30px;
        }

        .slider:before {
            position: absolute;
            content: "OFF";
            height: 24px;
            width: 36px;
            left: 3px;
            bottom: 3px;
            background-color: #ff4444;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            font-weight: bold;
            border-radius: 30px;
            transition: 0.3s;
        }

        input:checked + .slider:before {
            content: "ON";
            transform: translateX(24px);
            background-color: #44ff44;
            color: black;
        }

        .hs-value {
            text-align: center;
            font-size: 1.1rem;
            margin: 10px 0;
            color: #ff8888;
        }

        .mode-buttons {
            display: flex;
            gap: 10px;
            margin: 10px 0;
        }

        .mode-btn {
            flex: 1;
            background: #12172a;
            padding: 10px;
            text-align: center;
            border-radius: 40px;
            cursor: pointer;
            border: 1px solid gray;
        }

        .mode-btn.active {
            background: #ff3366;
            color: white;
            border-color: white;
        }

        .res-group {
            display: flex;
            gap: 10px;
            margin: 10px 0;
            flex-wrap: wrap;
        }

        .res-group input {
            flex: 1;
            background: #010a14;
            border: 1px solid cyan;
            padding: 10px;
            border-radius: 40px;
            color: #0ff;
            text-align: center;
        }

        .btn-apply {
            background: #ff9933;
            width: 100%;
            padding: 10px;
            border-radius: 40px;
            border: none;
            font-weight: bold;
            margin-top: 8px;
            cursor: pointer;
        }

        .shizuku-status {
            background: #1a1f2e;
            border-radius: 20px;
            padding: 10px;
            font-size: 0.7rem;
            text-align: center;
        }

        .status-msg {
            background: #010a0f;
            border-radius: 24px;
            padding: 10px;
            text-align: center;
            color: #0ff;
            font-size: 0.7rem;
            margin: 10px 0;
        }

        .btn-logout {
            background: #aa3355;
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 40px;
            margin-top: 14px;
            cursor: pointer;
            color: white;
        }

        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #00cc44;
            color: black;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: bold;
            z-index: 999;
            animation: fadeOut 2s ease;
        }

        @keyframes fadeOut {
            0% { opacity: 1; }
            70% { opacity: 1; }
            100% { opacity: 0; visibility: hidden; }
        }

        .info-small {
            font-size: 0.55rem;
            color: #aaa;
            text-align: center;
            margin-top: 8px;
        }

        button:active { transform: scale(0.97); }
        hr { border-color: cyan; margin: 12px 0; }
    </style>
</head>
<body>

<div class="app">
    <h1>⚡ VIP HS ULTIMATE</h1>
    <div class="sub">GENERATE KEY | AUTO HS 13% | RESOLUSI + DPI</div>

    <!-- GENERATE KEY -->
    <div id="genSection" class="gen-box">
        <button id="generateKeyBtn" class="btn-gen">🎲 GENERATE KEY BARU</button>
        <div id="keyArea" class="key-area">
            <div style="color:#0ff;">✨ KEY BARU ✨</div>
            <div id="newKeyValue" class="key-value">HS-XXXX-XXXX-XXXX-XXXX</div>
            <div class="copy-row">
                <button id="copyBtn1" class="copy-btn">📋 COPY</button>
                <button id="copyBtn2" class="copy-btn">📋 COPY 2</button>
            </div>
            <div class="info-small">💡 Klik teks key juga bisa copy</div>
        </div>
        <div id="keyListContainer" class="key-list"></div>
        <div class="info-small">* Key auto tersimpan di penyimpanan HP</div>
    </div>

    <!-- LOGIN -->
    <div id="loginSection" class="login-box">
        <label style="color:#0ff;">🔐 LOGIN PAKAI KEY</label>
        <input type="text" id="loginKeyInput" class="key-input" placeholder="Masukkan key dari atas" autocomplete="off">
        <button id="loginBtn" class="btn-login">▶ LOGIN KE DASHBOARD ◀</button>
    </div>

    <!-- DASHBOARD -->
    <div id="dashboard" class="dashboard">
        <div id="shizukuStatus" class="shizuku-status">🔍 Mengecek Shizuku...</div>

        <div class="card">
            <div class="toggle-row">
                <span style="color:#ff88aa; font-weight:bold;">🎯 AUTO HEADSHOT (13%)</span>
                <label class="switch">
                    <input type="checkbox" id="hsToggle">
                    <span class="slider"></span>
                </label>
            </div>
            <div id="hsDisplay" class="hs-value">⚡ HS: MATI</div>
        </div>

        <div class="card">
            <div style="color:#0ff; margin-bottom:8px;">🎮 VERSI GAME</div>
            <div class="mode-buttons">
                <div class="mode-btn" data-mode="max">🔥 FREE FIRE MAX</div>
                <div class="mode-btn" data-mode="th">🇹🇭 FREE FIRE TH</div>
            </div>
        </div>

        <div class="card">
            <div style="color:#0ff; margin-bottom:8px;">📱 UBAH RESOLUSI & DPI</div>
            <div class="res-group">
                <input type="number" id="widthRes" placeholder="Lebar" value="1080">
                <input type="number" id="heightRes" placeholder="Tinggi" value="2400">
            </div>
            <div class="res-group">
                <input type="number" id="dpiVal" placeholder="DPI" value="420">
            </div>
            <button id="applyResBtn" class="btn-apply">🔧 TERAPKAN RESOLUSI + DPI</button>
            <button id="resetResBtn" class="btn-apply" style="background:#6655aa; margin-top:6px;">🔄 RESET KE DEFAULT</button>
            <div class="info-small">* Wajib install Shizuku dan beri izin</div>
        </div>

        <div id="statusMsg" class="status-msg">✅ SYSTEM READY</div>
        <button id="logoutBtn" class="btn-logout">🚪 LOGOUT</button>
    </div>
</div>

<script>
    (function(){
        // ========== MASTER KEY SYSTEM ==========
        let masterKeys = [];

        function loadKeys() {
            try {
                let stored = localStorage.getItem("hs_master_keys");
                if(stored) {
                    masterKeys = JSON.parse(stored);
                }
                if(!masterKeys || masterKeys.length === 0) {
                    masterKeys = ["DEMO-8888-VIP-FF13", "TEST-HS13-ABCD-2024"];
                    saveKeys();
                }
                renderKeyList();
            } catch(e) {
                console.log("Load keys error:", e);
                masterKeys = ["DEMO-8888-VIP-FF13"];
                saveKeys();
                renderKeyList();
            }
        }

        function saveKeys() {
            try {
                localStorage.setItem("hs_master_keys", JSON.stringify(masterKeys));
            } catch(e) {}
        }

        function generateRandomKey() {
            const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ0123456789";
            let parts = [];
            for(let i = 0; i < 4; i++) {
                let seg = "";
                for(let j = 0; j < 4; j++) {
                    seg += chars.charAt(Math.floor(Math.random() * chars.length));
                }
                parts.push(seg);
            }
            return `HS-${parts[0]}-${parts[1]}-${parts[2]}-${parts[3]}`;
        }

        function addNewKey() {
            let newKey = generateRandomKey();
            if(!masterKeys.includes(newKey)) {
                masterKeys.push(newKey);
                saveKeys();
                renderKeyList();
                return newKey;
            }
            return addNewKey();
        }

        function deleteKey(keyToDelete) {
            masterKeys = masterKeys.filter(k => k !== keyToDelete);
            saveKeys();
            renderKeyList();
            showToast("🗑️ Key dihapus: " + keyToDelete);
        }

        function renderKeyList() {
            const container = document.getElementById("keyListContainer");
            if(!container) return;
            if(masterKeys.length === 0) {
                container.innerHTML = '<div style="color:#ff8888; text-align:center; padding:10px;">Belum ada key, klik GENERATE</div>';
                return;
            }
            container.innerHTML = masterKeys.map(k => `
                <div class="key-item">
                    <span class="key-span" data-key="${k}">🔑 ${k}</span>
                    <button class="item-copy" data-key="${k}">COPY</button>
                    <button class="item-del" data-key="${k}">HAPUS</button>
                </div>
            `).join('');

            document.querySelectorAll('.key-span').forEach(span => {
                span.addEventListener('click', () => {
                    const key = span.getAttribute('data-key');
                    copyToClipboard(key);
                    showToast("✅ Disalin: " + key);
                });
            });
            document.querySelectorAll('.item-copy').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const key = btn.getAttribute('data-key');
                    copyToClipboard(key);
                    showToast("✅ Disalin: " + key);
                });
            });
            document.querySelectorAll('.item-del').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const key = btn.getAttribute('data-key');
                    deleteKey(key);
                });
            });
        }

        // ========== COPY FUNCTION ==========
        function copyToClipboard(text) {
            if(!text) return;
            if(navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).catch(() => fallbackCopy(text));
            } else {
                fallbackCopy(text);
            }
        }

        function fallbackCopy(text) {
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.top = '-9999px';
            document.body.appendChild(textarea);
            textarea.select();
            try {
                document.execCommand('copy');
            } catch(e) {
                alert("Copy manual: " + text);
            }
            document.body.removeChild(textarea);
        }

        function showToast(msg) {
            let existing = document.querySelector('.toast');
            if(existing) existing.remove();
            let toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerText = msg;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2000);
        }

        // ========== VALIDASI LOGIN ==========
        function validateKey(inputKey) {
            return masterKeys.includes(inputKey.trim().toUpperCase());
        }

        let currentSession = null;

        function setSession(key) {
            currentSession = key;
            sessionStorage.setItem("hs_session", key);
        }

        function getSession() {
            let sess = sessionStorage.getItem("hs_session");
            if(sess && masterKeys.includes(sess)) {
                currentSession = sess;
                return sess;
            }
            return null;
        }

        function clearSession() {
            sessionStorage.removeItem("hs_session");
            currentSession = null;
        }

        // ========== SHIZUKU ==========
        let shizukuReady = false;

        async function checkShizuku() {
            const statusDiv = document.getElementById("shizukuStatus");
            if(!statusDiv) return;
            try {
                if(typeof Shizuku !== 'undefined' && Shizuku) {
                    const granted = await Shizuku.checkSelfPermission();
                    if(granted) {
                        shizukuReady = true;
                        statusDiv.innerHTML = "✅ SHIZUKU AKTIF | IZIN DITERIMA ✅";
                        statusDiv.style.color = "#0f0";
                        return;
                    }
                }
                statusDiv.innerHTML = "⚠️ SHIZUKU TIDAK DETEK ⚠️\nInstall Shizuku & beri izin";
                statusDiv.style.color = "#ffaa44";
                shizukuReady = false;
            } catch(e) {
                statusDiv.innerHTML = "❌ SHIZUKU ERROR";
                shizukuReady = false;
            }
        }

        async function executeShellCommand(command) {
            if(!shizukuReady) {
                showToast("⚠️ Shizuku tidak siap!", "#ff6600");
                return null;
            }
            try {
                if(typeof Shizuku !== 'undefined' && Shizuku) {
                    return await Shizuku.executeShellCommand(command);
                }
                return null;
            } catch(e) {
                showToast("❌ Gagal: " + e.message, "#ff4444");
                return null;
            }
        }

        async function setResolution(width, height) {
            let result = await executeShellCommand(`wm size ${width}x${height}`);
            if(result !== null) showToast("✅ Resolusi diubah ke " + width + "x" + height);
            return result !== null;
        }

        async function setDpi(dpi) {
            let result = await executeShellCommand(`wm density ${dpi}`);
            if(result !== null) showToast("✅ DPI diubah ke " + dpi);
            return result !== null;
        }

        async function resetResolutionDpi() {
            await executeShellCommand("wm size reset");
            await executeShellCommand("wm density reset");
            showToast("✅ Resolusi & DPI direset");
        }

        // ========== UI BINDINGS ==========
        const genSection = document.getElementById("genSection");
        const loginSection = document.getElementById("loginSection");
        const dashboardDiv = document.getElementById("dashboard");
        const generateBtn = document.getElementById("generateKeyBtn");
        const keyArea = document.getElementById("keyArea");
        const newKeyValue = document.getElementById("newKeyValue");
        const copyBtn1 = document.getElementById("copyBtn1");
        const copyBtn2 = document.getElementById("copyBtn2");
        const loginKeyInput = document.getElementById("loginKeyInput");
        const loginBtn = document.getElementById("loginBtn");
        const hsToggle = document.getElementById("hsToggle");
        const hsDisplay = document.getElementById("hsDisplay");
        const statusMsgDiv = document.getElementById("statusMsg");
        const logoutBtn = document.getElementById("logoutBtn");
        const widthRes = document.getElementById("widthRes");
        const heightRes = document.getElementById("heightRes");
        const dpiVal = document.getElementById("dpiVal");
        const applyResBtn = document.getElementById("applyResBtn");
        const resetResBtn = document.getElementById("resetResBtn");

        let currentGameMode = "max";
        let hsActive = false;
        let currentKey = "";

        generateBtn.onclick = () => {
            currentKey = addNewKey();
            newKeyValue.innerText = currentKey;
            keyArea.style.display = "block";
            showToast("🔑 Key baru: " + currentKey);
        };

        newKeyValue.onclick = () => {
            if(currentKey) {
                copyToClipboard(currentKey);
                showToast("✅ Disalin: " + currentKey);
            }
        };

        copyBtn1.onclick = () => {
            if(currentKey) {
                copyToClipboard(currentKey);
                showToast("✅ Disalin: " + currentKey);
            }
        };

        copyBtn2.onclick = () => {
            if(currentKey) {
                copyToClipboard(currentKey);
                showToast("✅ Disalin: " + currentKey);
            }
        };

        function updateHSDisplay() {
            hsDisplay.innerHTML = hsActive ? "🔴 AUTO HS: 13% AKTIF 🔴" : "⚫ AUTO HS: 0% (MATI) ⚫";
        }

        function updateModeUI() {
            document.querySelectorAll(".mode-btn").forEach(btn => {
                if(btn.getAttribute("data-mode") === currentGameMode) btn.classList.add("active");
                else btn.classList.remove("active");
            });
        }

        function updateStatus() {
            let modeStr = currentGameMode === "max" ? "FREE FIRE MAX" : "FREE FIRE TH";
            let hsStr = hsActive ? "HS ON 13%" : "HS OFF";
            statusMsgDiv.innerHTML = `🎮 ${modeStr} | ${hsStr} 🎮<br>📱 Target: ${widthRes.value}x${heightRes.value} | DPI: ${dpiVal.value}`;
        }

        hsToggle.onchange = (e) => {
            hsActive = e.target.checked;
            updateHSDisplay();
            updateStatus();
            showToast(hsActive ? "🔴 Auto HS 13% AKTIF" : "⚪ Auto HS dimatikan");
        };

        document.querySelectorAll(".mode-btn").forEach(btn => {
            btn.onclick = () => {
                currentGameMode = btn.getAttribute("data-mode");
                updateModeUI();
                updateStatus();
                showToast(`Mode: ${currentGameMode === "max" ? "FF MAX" : "FF TH"}`);
            };
        });

        applyResBtn.onclick = async () => {
            let w = parseInt(widthRes.value) || 1080;
            let h = parseInt(heightRes.value) || 2400;
            let d = parseInt(dpiVal.value) || 420;
            await setResolution(w, h);
            await setDpi(d);
            updateStatus();
        };

        resetResBtn.onclick = async () => {
            await resetResolutionDpi();
            widthRes.value = "1080";
            heightRes.value = "2400";
            dpiVal.value = "420";
            updateStatus();
        };

        loginBtn.onclick = async () => {
            let inputKey = loginKeyInput.value.trim().toUpperCase();
            if(!inputKey) { showToast("Masukkan key!", "#ff6600"); return; }
            if(validateKey(inputKey)) {
                setSession(inputKey);
                genSection.style.display = "none";
                loginSection.style.display = "none";
                dashboardDiv.style.display = "block";
                await checkShizuku();
                hsActive = false;
                hsToggle.checked = false;
                currentGameMode = "max";
                updateHSDisplay();
                updateModeUI();
                updateStatus();
                showToast("✅ Login sukses!");
            } else {
                showToast("❌ KEY INVALID! Generate dulu", "#ff4444");
            }
        };

        logoutBtn.onclick = () => {
            clearSession();
            genSection.style.display = "block";
            loginSection.style.display = "block";
            dashboardDiv.style.display = "none";
            loginKeyInput.value = "";
            showToast("🚪 Logout berhasil");
        };

        async function checkAutoLogin() {
            let sess = getSession();
            if(sess) {
                genSection.style.display = "none";
                loginSection.style.display = "none";
                dashboardDiv.style.display = "block";
                await checkShizuku();
                hsActive = false;
                hsToggle.checked = false;
                currentGameMode = "max";
                updateHSDisplay();
                updateModeUI();
                updateStatus();
            }
        }

        loadKeys();
        checkAutoLogin();

        window.addEventListener("storage", (e) => {
            if(e.key === "hs_master_keys") {
                loadKeys();
                if(currentSession && !validateKey(currentSession)) {
                    clearSession();
                    checkAutoLogin();
                }
            }
        });
    })();
</script>
</body>
</html>
